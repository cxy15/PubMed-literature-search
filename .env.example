# ---------- NCBI E-utilities（PubMed 检索）----------
# 政策要求的联系邮箱（用于标识调用方，不是登录密码）
ENTREZ_EMAIL=

# 可选：NCBI 账号申请的 API Key，请求会带 api_key=…，提高速率等
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# ---------- LLM：任意 OpenAI 兼容 HTTP 服务（不必是 ChatGPT）----------
# 服务根 URL，一般需包含 /v1，例如 https://api.deepseek.com/v1 或自建网关
OPENAI_BASE_URL=

# 该服务颁发的密钥（Bearer）；变量名沿用 OpenAI SDK 惯例
OPENAI_API_KEY=

# 模型名由服务商定义，例如 gpt-4o-mini、deepseek-chat 等
OPENAI_MODEL=

# 可选：中文字体路径（.ttf/.ttc），用于 PDF
# CHINESE_FONT_PATH=/Library/Fonts/Arial Unicode.ttf
